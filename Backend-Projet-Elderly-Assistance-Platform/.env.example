# Copy to .env and load in your shell/IDE, or export before starting Spring Boot.
# Never commit real secrets.

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/elderly_assistance_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=

# HS256 key: 64 hex chars (32 bytes) OR Base64-encoded key bytes
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
# Access token TTL (ms) — default 15 minutes
JWT_EXPIRATION_MS=900000
# Refresh token TTL (ms) — default 7 days
JWT_REFRESH_EXPIRATION_MS=604800000

# Production: use validate so Hibernate does not mutate schema (Flyway owns DDL)
# SPRING_JPA_HIBERNATE_DDL_AUTO=validate
